# Public site should stay read-only.
VITE_ENABLE_EDITOR=false

# Supabase connection (required for global published content)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: table and row id for the JSON content document
VITE_SUPABASE_CONTENT_TABLE=portfolio_content
VITE_SUPABASE_CONTENT_ID=main

# Optional: public bucket used for uploaded card images
VITE_SUPABASE_IMAGE_BUCKET=portfolio-art
